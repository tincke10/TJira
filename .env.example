  # ─── Jira credentials (REQUIRED) ────────────────────────────────────────────                                                               
  # Your Jira Cloud domain — just the host, without https:// or trailing slash.                                                                  
  JIRA_DOMAIN=your-company.atlassian.net                                                                                                       
                                                                                                                                                 
  # The email address tied to your Atlassian account.                                                                                          
  JIRA_EMAIL=your.email@company.com                                                                                                              
                                                                                                                                                 
  # API token from https://id.atlassian.com/manage-profile/security/api-tokens                                                                   
  # Treat this like a password — never commit it.                                                                                                
  JIRA_API_TOKEN=your_api_token_here                                                                                                             
                                                                                                                                                 
                                                                                                                                                 
  # ─── Optional tuning ────────────────────────────────────────────────────────                                                                 
  # IANA timezone used when parsing/formatting worklog timestamps.                                                                               
  # Defaults to your system local timezone when unset.                                                                                           
  # JIRA_TIMEZONE=America/Argentina/Buenos_Aires                                                                                                 
                                                                                                                                                 
  # HTTP timeout (in seconds) for every Jira API call. Defaults to 30.                                                                           
  # JIRA_TIMEOUT=30   